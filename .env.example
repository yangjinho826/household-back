# =============================================
# 애플리케이션
# =============================================
APP_NAME=household
DEBUG=false                              # 운영은 false. 로컬 dev 만 true
DOCKER_IMAGE_NAME=household-back
DOCKER_CONTAINER_NAME=household-back

# =============================================
# 데이터베이스
# =============================================
# 운영/docker: 강력한 PASSWORD 로 교체
POSTGRES_USER=household
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=HOUSEHOLD
# docker-compose 가 DATABASE_URL 을 자동 합성 (postgres 호스트). 로컬 dev 면 127.0.0.1 로 덮어쓰기.
DATABASE_URL=postgresql+asyncpg://household:change-me-strong-password@postgres:5432/HOUSEHOLD
DB_POOL_MIN=10
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30

# =============================================
# 로깅
# =============================================
LOG_LEVEL=INFO

# =============================================
# CORS
# =============================================
# 운영 도메인 화이트리스트. nginx 뒤 same-origin 이면 사실상 미사용이지만 SSR/외부 호출 대비.
ALLOWED_ORIGINS=["https://your-domain.example.com"]

# =============================================
# JWT
# =============================================
# 운영 시 반드시 강력한 secret 으로 교체: openssl rand -hex 32
JWT_SECRET=change-me-to-at-least-256-bits-long-secret-for-hs256
JWT_EXPIRATION=1800                       # access token: 30분
JWT_REFRESH_EXPIRATION=604800             # refresh token: 7일
