# =============================================
# 애플리케이션
# =============================================
APP_NAME=household
DEBUG=true
DOCKER_IMAGE_NAME=household-back
DOCKER_CONTAINER_NAME=household-back

# =============================================
# 데이터베이스
# =============================================
POSTGRES_USER=household
POSTGRES_PASSWORD=1234
POSTGRES_DB=HOUSEHOLD
DATABASE_URL=postgresql+asyncpg://household:1234@postgres:5432/HOUSEHOLD
DB_POOL_MIN=10
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30

# =============================================
# 로깅
# =============================================
LOG_LEVEL=INFO

# =============================================
# CORS
# =============================================
ALLOWED_ORIGINS=["http://localhost:3000"]

# =============================================
# JWT
# =============================================
JWT_SECRET=change-me-to-at-least-256-bits-long-secret-for-hs256
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800
