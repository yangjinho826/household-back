# rclone 설정 템플릿 — install.sh 가 .env 의 R2_* 변수를 envsubst 로 채워서
# ~/.config/rclone/rclone.conf 에 배치한다.
#
# 수동 갱신 시: install.sh 다시 실행하면 됨.
[r2]
type = s3
provider = Cloudflare
access_key_id = ${R2_ACCESS_KEY_ID}
secret_access_key = ${R2_SECRET_ACCESS_KEY}
endpoint = https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
acl = private
no_check_bucket = true
